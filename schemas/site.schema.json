{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmm.local/schemas/site.schema.json",
  "title": "MMM Site Metadata",
  "type": "object",
  "required": ["schemaVersion", "name", "tagline", "description", "baseUrl", "author", "navigation"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "type": "string" },
    "name": { "type": "string" },
    "tagline": { "type": "string" },
    "description": { "type": "string" },
    "baseUrl": { "type": "string", "format": "uri" },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": ["string", "null"], "format": "email" },
        "tumblr": { "type": ["string", "null"], "format": "uri" }
      },
      "additionalProperties": false
    },
    "navigation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "path"],
        "properties": {
          "label": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "socialLinks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
