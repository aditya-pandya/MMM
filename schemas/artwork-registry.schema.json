{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MMM Artwork Registry",
  "type": "object",
  "required": ["schemaVersion", "updatedAt", "items"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "mixSlug",
          "role",
          "assetPath",
          "workspacePath",
          "registeredAt",
          "file",
          "checksum",
          "provenance"
        ],
        "properties": {
          "id": { "type": "string" },
          "mixSlug": { "type": "string" },
          "role": { "type": "string" },
          "assetPath": { "type": "string" },
          "workspacePath": { "type": "string" },
          "registeredAt": { "type": "string" },
          "file": {
            "type": "object",
            "required": ["byteSize", "mediaType"],
            "properties": {
              "byteSize": { "type": "integer", "minimum": 0 },
              "mediaType": { "type": "string" },
              "etag": { "type": ["string", "null"] },
              "lastModified": { "type": ["string", "null"] }
            }
          },
          "checksum": {
            "type": "object",
            "required": ["algorithm", "value"],
            "properties": {
              "algorithm": { "const": "sha256" },
              "value": { "type": "string" }
            }
          },
          "provenance": {
            "type": "object",
            "required": ["sourceType", "sourceLabel", "sourceUrl", "discoveredFrom", "notes"],
            "properties": {
              "sourceType": { "type": "string" },
              "sourceLabel": { "type": "string" },
              "sourceUrl": { "type": "string" },
              "discoveredFrom": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
