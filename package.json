{
  "name": "mmm",
  "version": "1.0.0",
  "description": "Automation and static build tooling for Monday Music Mix",
  "type": "commonjs",
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/dev-server.js",
    "preview": "npm run build && python3 -m http.server 4173 -d dist",
    "test": "python3 -m pytest",
    "draft:generate": "python3 scripts/generate_weekly_draft.py --mode auto",
    "draft:generate:ai": "python3 scripts/generate_weekly_draft.py --mode ai",
    "publish": "python3 scripts/publish_mix.py",
    "content:validate": "python3 scripts/validate_content.py",
    "content:refresh": "python3 scripts/refresh_indexes.py",
    "artwork:scaffold": "python3 scripts/manage_artwork.py scaffold",
    "artwork:register": "python3 scripts/manage_artwork.py register",
    "artwork:generate:ai": "python3 scripts/generate_ai_artwork.py",
    "artwork:sync:tumblr": "python3 scripts/sync_tumblr_artwork.py",
    "tumblr:archive:import": "python3 scripts/import_tumblr_archive.py",
    "youtube:match": "python3 scripts/sync_youtube_matches.py",
    "draft:new": "python3 scripts/create_content.py draft-mix",
    "note:new": "python3 scripts/create_content.py note",
    "note:new-from-mix": "python3 scripts/create_content.py note-from-mix",
    "note:suggest": "python3 scripts/create_content.py suggest-notes",
    "preview:latest": "python3 scripts/preview_latest.py",
    "workflow:weekly": "./scripts/run_local_workflow.sh",
    "workflow:weekly:ai": "./scripts/run_local_workflow.sh --ai",
    "workflow:weekly:ai-art": "./scripts/run_local_workflow.sh --ai --with-ai-artwork",
    "workflow:weekly:scheduled": "./scripts/run_local_workflow.sh --scheduled",
    "workflow:schedule:install": "python3 ops/install_launch_agent.py --install --verify"
  },
  "keywords": [
    "music",
    "static-site",
    "automation"
  ],
  "license": "ISC"
}
